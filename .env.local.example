GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_ID=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
ANTHROPIC_API_KEY=
BRAVE_SEARCH_API_KEY=

# ── Google Contacts Sync ──────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com/
# 1. Create a project → Enable "People API"
# 2. OAuth consent screen → External → Add scope: contacts.readonly
# 3. Credentials → Create OAuth 2.0 Client ID → Web application
#    Authorized redirect URI: http://localhost:3000/api/auth/google/callback
# 4. Copy the Client ID and Secret below
GOOGLE_CLIENT_ID=your_client_id_here
GOOGLE_CLIENT_SECRET=your_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ── Resend Email ─────────────────────────────────────────────────────────────
# Get your key at https://resend.com/api-keys
# From domain: use onboarding@resend.dev for testing, or verify your own domain
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
RESEND_FROM_NAME=My Dispatch
